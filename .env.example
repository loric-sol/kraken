# Phase 1 MVP uses Kraken's public REST API for market data (no key needed)
# and the local `kraken` CLI's paper trading ledger (no key needed).
#
# These are placeholders for Phase 4 (live trading), NOT used by the MVP.
# Do not put real keys here / do not commit a populated .env.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Massive Market Data REST API key, used for DEEP historical OHLC backfills
# (data/massive_rest.py) that remove Kraken's ~720-candle cap for backtesting.
# Optional: only needed when fetching with --source massive.
MASSIVE_API_KEY=
# MASSIVE_BASE_URL=https://api.massive.com   # override only if needed
